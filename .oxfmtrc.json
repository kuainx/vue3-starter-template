{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["src/components/ui/**"],
  "singleQuote": true,
  "semi": false,
  "sortImports": {
    "groups": [
      ["side_effect", "side_effect_style"],
      { "newlinesBetween": true },
      "external",
      "named-external",
      { "newlinesBetween": true },
      "import",
      "named-import",
      { "newlinesBetween": true },
      "type"
    ],
    "newlinesBetween": false
  },
  "sortTailwindcss": {}
}
